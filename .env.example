APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
DEMO_ACCOUNTS_ENABLED=true

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional notification channels. Without these keys, database notifications keep working.
FCM_SERVER_KEY=
TELEGRAM_BOT_TOKEN=

# Geo / Routing
GEO_GEOCODER=nominatim
GEO_ROUTING=osrm
GEO_TILES=osm
NOMINATIM_USER_AGENT="TruckRoute/1.0 (contact: you@example.com)"
YANDEX_API_KEY=
YANDEX_GEOCODER_API_KEY=
YANDEX_JS_API_KEY=
YANDEX_MAPKIT_API_KEY=
OSRM_BASE_URL=https://router.project-osrm.org

# Firebase Cloud Messaging — опционально, для пуша на мобилку
FCM_SERVER_KEY=

# Сидер админа
ADMIN_EMAIL=admin@truckroute.local
ADMIN_PASSWORD=change-this-password
