# Для Expo Go по локальной сети:
# EXPO_PUBLIC_API_URL=http://192.168.1.20:8000/api/v1
#
# При запуске через tunnel запросы /api/v1 проксируются Metro-сервером,
# поэтому переменную можно не задавать.
EXPO_PUBLIC_API_URL=

# Локальный Laravel, к которому обращается Metro proxy.
LARAVEL_API_ORIGIN=http://127.0.0.1:8000
